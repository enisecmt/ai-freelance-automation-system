        "jsCode": "const veriler = $input.all().map(item => item.json);\n\nlet toplam_is = veriler.length;\nlet acil_is = 0;\nlet kategori_dagilimi = {};\n\nfor (let is of veriler) {\n  if (is.skor >= 8 || is.durum === 'Acil') acil_is++;\n  \n  let kat = is.kategori || 'Bilinmiyor';\n  if (kategori_dagilimi[kat]) {\n    kategori_dagilimi[kat]++;\n  } else {\n    kategori_dagilimi[kat] = 1;\n  }\n}\n\nlet ozet_metin = `HaftalГ„Вұk Г„В°Г…Её ГғвҖ“zeti:\\n\\nToplam Gelen Talep: ${toplam_is}\\nAcil/ГғвҖ“nemli Talep: ${acil_is}\\n\\nKategori DaГ„ЕёГ„ВұlГ„ВұmГ„Вұ:\\n`;\n\nfor (let kat in kategori_dagilimi) {\n  ozet_metin += `- ${kat}: ${kategori_dagilimi[kat]}\\n`;\n}\n\nreturn [{\n  json: {\n    haftalik_ozet: ozet_metin\n  }\n}];"
